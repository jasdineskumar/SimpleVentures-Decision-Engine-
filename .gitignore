# SV Pipeline .gitignore

# ===== Environment & Secrets =====
.env
*.env
credentials.json
token.json
service_account.json
service-account.json
client_secret_*.json

# ===== Temporary & Intermediate Files =====
.tmp/
*.tmp

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ===== Virtual Environments =====
venv/
env/
ENV/
env.bak/
venv.bak/

# ===== IDE =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== OS =====
.DS_Store
Thumbs.db
nul

# ===== Logs =====
*.log
logs/

# ===== Testing =====
.pytest_cache/
.coverage
htmlcov/

# ===== Keep template files =====
!.env.template
